---
interface Props {
  currentPath?: string;
}

const { currentPath } = Astro.props;
---

<nav
  class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-neutral-50/80 border-b border-neutral-200/50"
>
  <div
    class="w-full px-6 grid grid-cols-3 [@media(hover:none)]:grid-cols-2 items-center h-16"
  >
    <!-- Left: Name -->
    <div class="justify-self-start">
      <a
        href="/"
        class="text-sm font-semibold text-neutral-700 hover:text-neutral-950 transition-colors"
      >
        Eduardo Gómez
      </a>
    </div>

    <!-- Center: Work + About -->
    <div
      class="justify-self-center flex items-center gap-6 [@media(hover:none)]:justify-self-end"
    >
      <a
        href="/"
        class="text-sm font-semibold text-neutral-700 hover:text-neutral-950 transition-colors"
      >
        Work
      </a>
      <a
        href="/about"
        class="text-sm font-semibold text-neutral-700 hover:text-neutral-950 transition-colors"
      >
        About
      </a>
    </div>

    <!-- Right: Resume -->
    <div class="justify-self-end block [@media(hover:none)]:hidden">
      <a
        href="https://drive.google.com/file/d/1_04Tb40MW0qUbG5DVRib9dncND58ky8l/view?usp=drive_link"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-semibold text-neutral-700 hover:text-neutral-950 transition-colors"
      >
        Resume
      </a>
    </div>
  </div>
</nav>
