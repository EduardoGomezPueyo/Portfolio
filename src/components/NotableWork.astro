---
import type { Lang } from '../i18n/languages';
import { useTranslations } from '../i18n/utils';
import ScrollReveal from './ScrollReveal.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// INSTRUCCIONES:
// Aquí puedes añadir los nombres de tus 16 imágenes. 
// Para ordenarlas, simplemente cambia el orden de las líneas en estas listas.
// Asegúrate de que las imágenes estén en la carpeta 'public/images/'

const lightImages = [
  'agent-prompt-editor-light.jpg',
  'email-editor-light.jpg',
  'dashboard-view-creator-light.jpg',
  'form-components-light.jpg',
  'calendar-modal-light.jpg',
  'intensity-of-activity-light.jpg',
  'calendar-options-light.jpg',
  'hover-details-light.jpg',
  'notifications-light.jpg',
  'heatmap-chart-light.jpg',
  'date-selector-light.jpg',
  'notetaker-log-light.jpg',
  'select-component-light.jpg',
  'transfer-call-light.jpg',
  'button-component-light.jpg',
  'color-palette-light.jpg',
];

const darkImages = [
  'agent-prompt-editor-dark.jpg',
  'email-editor-dark.jpg',
  'dashboard-view-creator-dark.jpg',
  'form-components-dark.jpg',
  'calendar-modal-dark.jpg',
  'intensity-of-activity-dark.jpg',
  'calendar-options-dark.jpg',
  'hover-details-dark.jpg',
  'notifications-dark.jpg',
  'heatmap-chart-dark.jpg',
  'date-selector-dark.jpg',
  'notetaker-log-dark.jpg',
  'select-component-dark.jpg',
  'transfer-call-dark.jpg',
  'button-component-dark.jpg',
  'color-palette-dark.jpg',
];
---

<ScrollReveal>
  <section class="work-section py-20 md:py-28 max-w-content mx-auto px-6 bg-neutral-50 dark:bg-neutral-950" id="work">
    <div class="work-section__header mb-12">
      <h2 class="font-mono text-sm text-neutral-500 dark:text-neutral-400 uppercase tracking-wider">
        {t('home.notableWork')}
      </h2>
    </div>

    <div class="work-section__gallery">
      <!-- Contenedor Modo Claro -->
      <div class="work-gallery work-gallery--light">
        {lightImages.map((img) => (
          <img src={`/images/work-images/${img}`} alt="Work" class="work-image" loading="lazy" />
        ))}
      </div>

      <!-- Contenedor Modo Oscuro -->
      <div class="work-gallery work-gallery--dark">
        {darkImages.map((img) => (
          <img src={`/images/work-images/${img}`} alt="Work" class="work-image" loading="lazy" />
        ))}
      </div>
    </div>
  </section>
</ScrollReveal>

<style>
  .work-section {
    width: 100%;
    overflow: hidden;
    /* Ensure the section takes the background color from Tailwind classes */
  }

  @media (max-width: 639px) {
    .work-section {
      max-width: 100%;
    }
  }

  .work-gallery {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1.5rem; 
  }

  .work-image {
    width: 75%;
    margin-left: auto;
    margin-right: auto;
    height: auto;
    display: block;
    object-fit: cover;
    border-radius: 0.75rem;
  }

  @media (max-width: 639px) {
    .work-image {
      width: 100%;
    }
  }

  /* Lógica de cambio de tema */
  .work-gallery--dark {
    display: none;
  }

  :global(.dark) .work-gallery--light {
    display: none;
  }

  :global(.dark) .work-gallery--dark {
    display: flex;
  }
</style>
